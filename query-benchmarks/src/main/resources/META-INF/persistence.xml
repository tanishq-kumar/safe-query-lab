<?xml version="1.0" encoding="UTF-8"?>
<!-- Benchmarks bootstrap Hibernate WITHOUT Spring (no context startup noise in
     the measurements), so the two JPA-based engines need a classic persistence
     unit. JDBC coordinates are injected programmatically by EngineState. -->
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
  <persistence-unit name="bench" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
    <class>dev.querylab.engine.jpa.TransactionEntity</class>
    <class>dev.querylab.engine.querydsl.TransactionEntity</class>
    <exclude-unlisted-classes>true</exclude-unlisted-classes>
  </persistence-unit>
</persistence>
