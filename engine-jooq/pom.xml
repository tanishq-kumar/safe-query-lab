<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>dev.querylab</groupId>
    <artifactId>safe-query-lab</artifactId>
    <version>0.1.0-SNAPSHOT</version>
  </parent>

  <artifactId>engine-jooq</artifactId>
  <name>engine-jooq</name>
  <description>Technique 3: jOOQ. Code generated from the real Flyway schema (throwaway Postgres container at build time); DSL.noCondition() predicate composition; the same Condition object reused for data and count queries.</description>

  <dependencies>
    <dependency>
      <groupId>dev.querylab</groupId>
      <artifactId>query-common</artifactId>
    </dependency>
    <dependency>
      <groupId>org.jooq</groupId>
      <artifactId>jooq</artifactId>
    </dependency>

    <dependency>
      <groupId>dev.querylab</groupId>
      <artifactId>query-conformance</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <!-- Codegen against a REAL PostgreSQL (throwaway container) running the same Flyway
           migrations the app and tests use — schema drift between codegen and runtime is
           impossible. Docker is already a hard requirement for tests, so this costs nothing.
           Docker-less fallback: switch to org.jooq.meta.extensions.ddl.DDLDatabase (loses
           pg_trgm/timestamptz fidelity). Run once after clone for IDEs:
           ./mvnw -pl engine-jooq generate-sources -->
      <plugin>
        <groupId>org.testcontainers</groupId>
        <artifactId>testcontainers-jooq-codegen-maven-plugin</artifactId>
        <dependencies>
          <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>postgresql</artifactId>
            <version>${testcontainers.version}</version>
          </dependency>
          <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>${postgresql.version}</version>
          </dependency>
          <!-- Pin the plugin's jOOQ to the Boot-managed runtime version: codegen/runtime
               version skew is a classic source of subtle breakage. -->
          <dependency>
            <groupId>org.jooq</groupId>
            <artifactId>jooq-codegen</artifactId>
            <version>${jooq.version}</version>
          </dependency>
        </dependencies>
        <executions>
          <execution>
            <id>generate-jooq-sources</id>
            <phase>generate-sources</phase>
            <goals>
              <goal>generate</goal>
            </goals>
            <configuration>
              <database>
                <type>POSTGRES</type>
                <containerImage>postgres:16-alpine</containerImage>
              </database>
              <flyway>
                <locations>filesystem:${project.basedir}/../query-common/src/main/resources/db/migration</locations>
              </flyway>
              <jooq>
                <generator>
                  <database>
                    <inputSchema>public</inputSchema>
                    <includes>.*</includes>
                    <excludes>flyway_schema_history</excludes>
                  </database>
                  <generate>
                    <javaTimeTypes>true</javaTimeTypes>
                  </generate>
                  <target>
                    <packageName>dev.querylab.engine.jooq.generated</packageName>
                    <directory>${project.build.directory}/generated-sources/jooq</directory>
                  </target>
                </generator>
              </jooq>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
